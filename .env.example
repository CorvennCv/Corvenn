# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: postgres://postgres:postgres@localhost:5432/novacv
# Production: use your managed Postgres provider's connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/novacv

# Staging: a separate database, used by `npm run migrate:staging` / `seed:staging` /
# `deploy:staging` (via --staging) instead of DATABASE_URL. Never point this at prod.
STAGING_DATABASE_URL=

# ── Auth.js (NextAuth) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "false" to run without login (single-user / self-hosted mode)
NEXT_PUBLIC_AUTH_ENABLED=true
# Set to "true" to enable SaaS features (pricing, billing, upgrade prompts)
NEXT_PUBLIC_SAAS_MODE=false

# ── OAuth providers (optional — leave blank to disable) ───────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
# Callback URL: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → OAuth Apps
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── SMTP (password reset emails) ──────────────────────────────────────────────
# Leave blank to skip sending (reset link printed to console instead)
# Gmail: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NovaCV <noreply@novacv.app>

# ── AI Provider Keys (optional — used for resume AI features) ─────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
