{
  "name": "corvenn-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "migrate": "node scripts/migrate.js",
    "migrate:staging": "node scripts/migrate.js --staging",
    "seed": "node scripts/seed.js",
    "seed:staging": "node scripts/seed.js --staging",
    "deploy:staging": "npm run build && npm run migrate:staging && npm run seed:staging"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0"
  }
}
