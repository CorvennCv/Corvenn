{
  "manifest_version": 3,
  "name": "Corvenn Job Tracker",
  "version": "1.1",
  "icons": {
    "128": "icon.png"
  },
  "description": "Save job postings directly to your Corvenn Kanban board.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}